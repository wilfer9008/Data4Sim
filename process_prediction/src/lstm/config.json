{
  "data": {
    "data_dir": "/home/mkfari/Data4Sim_New/final data4sim/data_preprocessed",
    "csv_glob": "S*.csv",
    "input_col": "features",
    "output_col": "Mid-Level Process",
    "hz": 100,

    "big_window_minutes": 30,
    "big_overlap_minutes": 1,

    "small_window_seconds": 5,
    "small_overlap_seconds": 1,

    "cover_all_samples": true
  },

  "split": {
    "train_ratio": 0.8,
    "val_ratio": 0.1,
    "seed": 42
  },
  "train": {
    "batch_size": 1,
    "epochs": 100,
    "lr": 0.001,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "l1_lambda": 1e-05,
    "device": "cuda",
    "out_dir": "runs/lstm_process_mining",
    "optimizer": "adamw"
  },
  "model": {
    "emb_dim": 64,
    "hidden_dim": 64,
    "layers": 2,
    "dropout": 0.3
  }
}
